<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vape Store Locator</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css"
    />
    <link rel="stylesheet" href="/styles.css" />
    <style>
      .add-store-form {
        display: none;
        padding: 15px;
        background: #f9f9f9;
        border-radius: 8px;
        margin-top: 15px;
      }
      #map {
        height: 400px;
        width: 100%;
        margin-top: 20px;
      }
      .thumbnail {
        display: block;
        margin-top: 10px;
        border-radius: 5px;
      }
      .add-button {
        display: block;
        margin: 10px auto;
        background-color: #007bff;
        color: white;
        padding: 10px 20px;
        border: none;
        cursor: pointer;
        border-radius: 5px;
      }
    </style>
  </head>
  <body>
    <%- include('header') %>

    <div class="container">
      <h1 class="center-align">Vape Store Locator</h1>

      <button class="add-button" id="fab">Add Store</button>

      <div class="add-store-form">
        <form
          action="/add-store"
          method="POST"
          class="col s12"
          enctype="multipart/form-data"
        >
          <div class="row">
            <div class="input-field col s6">
              <input
                type="text"
                id="address"
                name="address"
                placeholder="Address"
              />
            </div>
            <div class="input-field col s6">
              <input
                type="text"
                id="name"
                name="name"
                placeholder="Store Name"
                required
              />
            </div>

            <div class="input-field col s6">
              <input
                type="text"
                id="contact_info"
                name="contact_info"
                placeholder="Contact Info"
                required
              />
            </div>

            <div class="input-field col s6">
              <input
                type="file"
                id="image"
                name="image"
                accept="image/*"
                required
              />
            </div>
            <div class="input-field col s6">
                <label>
                  <input type="checkbox" id="parking" name="parking" />
                  <span>Parking Available</span>
                </label>
              </div>
          </div>
          <button type="submit" class="btn">Add Store</button>
        </form>
      </div>

      <ul class="collection">
        <% stores.forEach(store => { %>
        <li class="collection-item">
          <strong
            ><a href="/store/<%= store.id %>"><%= store.name %></a></strong
          >
          <p style="margin: 8px"><%= store.address %></p>
          <% if (store.image) { %>
          <img
            class="thumbnail"
            src="data:image/jpeg;base64,<%= store.image.toString('base64') %>"
            alt="Store Image"
          />
          <% } %>
        </li>
        <% }); %>
      </ul>

      <div id="map"></div>
    </div>

    <%- include('footer') %>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>

    <script
      src="https://maps.googleapis.com/maps/api/js?key=AIzaSyDcMs8Q8YSQQssB6s_kU_5ygLubCAKoAR0&libraries=places&callback=initMap"
      async
      defer
    ></script>

    <script>
          let map;
          let marker;

          function autofill (){
              const storeInput = document.getElementById("name");
              const autocomplete = new google.maps.places.Autocomplete(name);
          }

          function initMap() {
          const stores = <%- JSON.stringify(stores) %>; // All stores data

          // Default coordinates for the map (centered in case of no stores)
          const defaultLatLng = { lat: 37.7749, lng: -122.4194 }; // San Francisco (change this if needed)

          // Set the initial center based on the first store's latitude and longitude
          const firstStore = stores.length > 0 ? stores[0] : null;
          const center = firstStore ? { lat: parseFloat(firstStore.latitude), lng: parseFloat(firstStore.longitude) } : defaultLatLng;

          // Create the map
          map = new google.maps.Map(document.getElementById('map'), {
              center: center,
              zoom: 12,
          });

          // Loop through stores and add markers
          stores.forEach(store => {
              new google.maps.Marker({
                  position: { lat: parseFloat(store.latitude), lng: parseFloat(store.longitude) },
                  map: map,
                  title: store.name,
              });
          });

          marker = new google.maps.Marker({
              position: defaultLatLng,
              map: map,
          });

          const addressInput = document.getElementById("address");
          const autocomplete = new google.maps.places.Autocomplete(addressInput);
          autocomplete.bindTo("bounds", map);

          // Add listener for when a place is selected
          autocomplete.addListener("place_changed", function () {
              const place = autocomplete.getPlace();
              if (!place.geometry) {
                  return;
              }

              // Autofill the store name and contact info fields
              document.getElementById('name').value = place.name || '';
              document.getElementById('contact_info').value = place.formatted_phone_number || '';

              // Reveal additional fields and submit button
              document.getElementById('additional-fields').style.display = 'block';
              document.getElementById('submit-button').style.display = 'block';
          });

          // Add markers for existing stores
          stores.forEach(store => {
              new google.maps.Marker({
                  position: { lat: parseFloat(store.latitude), lng: parseFloat(store.longitude) },
                  map: map,
                  title: store.name,
              });
          });
      }

          document.getElementById("fab").onclick = function () {
              const form = document.querySelector(".add-store-form");
              form.style.display = form.style.display === "block" ? "none" : "block";
          };
    </script>
  </body>
</html>
