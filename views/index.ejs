<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Vape Store Locator</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css"
    />
    <link rel="stylesheet" href="/styles.css" />
    <style>
        .add-store-form {
            display: none;
            padding: 15px;
            background: #f9f9f9;
            border-radius: 8px;
            margin-top: 15px;
        }
        #map {
            height: 400px;
            width: 100%;
            margin-top: 20px;
        }
        .thumbnail {
            display: block;
            margin-top: 10px;
            border-radius: 5px;
        }
        .add-button {
            display: block;
            margin: 10px auto;
            background-color: #007bff;
            color: white;
            padding: 10px 20px;
            border: none;
            cursor: pointer;
            border-radius: 5px;
        }

    </style>
  </head>
  <body>
    <%- include('header') %>

    <div class="container">
        <h1 class="center-align">Vape Store Locator</h1>
        
        <button class="add-button" id="fab">Add Store</button>
        
        <div class="add-store-form">
            <form action="/add-store" method="POST" class="col s12" enctype="multipart/form-data">
                <div class="row">
                    <div class="input-field col s6">
                        <input type="text" id="name" name="name" required>
                        <label for="name">Store Name</label>
                    </div>
                    <div class="input-field col s6">
                        <input type="text" id="address" name="address" required>
                        <label for="address">Address</label>
                    </div>
                    <div class="input-field col s6">
                        <input type="text" id="contact_info" name="contact_info" required>
                        <label for="contact_info">Contact Info</label>
                    </div>
                    <div class="input-field col s6">
                        <input type="file" id="image" name="image" accept="image/*" required>
                    </div>
                </div>
                <button type="submit" class="btn">Add Store</button>
            </form>
        </div>
        
        <ul class="collection">
            <% stores.forEach(store => { %>
                <li class="collection-item">
                    <strong><a href="/store/<%= store.id %>"><%= store.name %></a></strong>
                    <p style="margin: 8px;"><%= store.address %></p>
                    <% if (store.image) { %>
                        <img class="thumbnail" src="data:image/jpeg;base64,<%= store.image.toString('base64') %>" alt="Store Image">
                    <% } %>
                    <!-- Remove Button -->
                    <form action="/store/<%= store.id %>/delete" method="POST" style="display:inline;">
                        <button type="submit" class="btn red">Remove</button>
                    </form>
                </li>
            <% }); %>
        </ul>


      <!-- Google Maps display -->
      <div id="map"></div>
    </div>

    <div class="recommended-stores-container">
      <h2>⭐ Recommended Stores ⭐</h2>
      
      <div class="recommended-stores">
        <% recommendedStores.forEach(store => { %>
          <div class="store-card">
            <img src="<%= store.image %>" alt="<%= store.name %> Thumbnail">
            <div class="store-info">
              <h3><%= store.name %></h3>
              <p><%= store.address %></p>
            </div>
            <button class="add-store-btn" data-name="<%= store.name %>" data-address="<%= store.address %>" data-image="<%= store.image %>">Add to My Stores</button>
          </div>
        <% }); %>
      </div>

    <div>
      <button id="refresh-recommendations">Refresh</button>
    </div>
    

    <%- include('footer') %>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>

    <!-- Google Maps API script using .env -->
    <script src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsApiKey %>&callback=initMap" async defer></script>

    <script>
        document.getElementById('fab').onclick = function() {
            const form = document.querySelector('.add-store-form');
            form.style.display = form.style.display === 'block' ? 'none' : 'block';
        };

        // Initialize the Google Map and display markers
        function initMap() {
            const stores = <%- JSON.stringify(stores) %>; // All stores data

            // Default coordinates for the map (centered in case of no stores)
            const defaultLatLng = { lat: 37.7749, lng: -122.4194 }; // San Francisco (change this if needed)

            // Set the initial center based on the first store's latitude and longitude
            const firstStore = stores.length > 0 ? stores[0] : null;
            const center = firstStore ? { lat: parseFloat(firstStore.latitude), lng: parseFloat(firstStore.longitude) } : defaultLatLng;

            // Create the map
            const map = new google.maps.Map(document.getElementById('map'), {
                center: center,
                zoom: 12,
            });

            // Loop through stores and add markers
stores.forEach(store => {
    new google.maps.Marker({
        position: { lat: parseFloat(store.latitude), lng: parseFloat(store.longitude) },
        map: map,
        title: store.name,
    });
});
        }
    </script>

      <script>
        // Store all recommended stores data for client-side refresh
        const allRecommendedStores = <%- JSON.stringify(allRecommendedStores || []) %>;
        
        // Function to get random stores
        function getRandomStores(stores, count) {
          const shuffled = [...stores].sort(() => 0.5 - Math.random());
          return shuffled.slice(0, count);
        }
        
        // Function to refresh the recommended stores section
        function refreshRecommendedStores() {
          if (allRecommendedStores.length === 0) {
            return; // Nothing to refresh
          }
          
          const recommendedStoresContainer = document.querySelector('.recommended-stores');
          const randomStores = getRandomStores(allRecommendedStores, 3);
          
          // Clear current stores
          recommendedStoresContainer.innerHTML = '';
          
          // Add new random stores
          randomStores.forEach(store => {
            const storeCard = document.createElement('div');
            storeCard.className = 'store-card';
            
            storeCard.innerHTML = `
              <img src="${store.image}" alt="${store.name} Thumbnail">
              <div class="store-info">
                <h3>${store.name}</h3>
                <p>${store.address}</p>
              </div>
              <button class="add-store-btn" data-name="${store.name}" data-address="${store.address}" data-image="${store.image}">Add to My Stores</button>
            `;
            
            recommendedStoresContainer.appendChild(storeCard);
          });
          
          // Re-attach event listeners to new buttons
          attachAddStoreEvents();
        }
        
        // Function to attach event listeners to add store buttons
        function attachAddStoreEvents() {
          document.querySelectorAll('.add-store-btn').forEach(button => {
            button.addEventListener('click', function() {
              const name = this.getAttribute('data-name');
              const address = this.getAttribute('data-address');
              const image = this.getAttribute('data-image');
              
              // Add your logic here to add the store to your database
              console.log(`Adding store: ${name}, ${address}, ${image}`);
              
              // You could implement an AJAX call here if you want to add the store without page refresh
              // For example:
              /*
              fetch('/add-recommended-store', {
                method: 'POST',
                headers: {
                  'Content-Type': 'application/json'
                },
                body: JSON.stringify({ name, address, image })
              })
              .then(response => response.json())
              .then(data => {
                if (data.success) {
                  alert('Store added successfully!');
                }
              });
              */
            });
          });
        }
        
        // Attach event listener to refresh button
        document.getElementById('refresh-recommendations').addEventListener('click', refreshRecommendedStores);
        
        // Initial attachment of events
        attachAddStoreEvents();
      </script>

      <script>
  document.addEventListener("DOMContentLoaded", () => {
    document.querySelectorAll(".add-store-btn").forEach(button => {
      button.addEventListener("click", async (event) => {
        const btn = event.target;
        
        // Get store details from button attributes
        const storeData = {
          name: btn.dataset.name,
          address: btn.dataset.address,
          image: btn.dataset.image
        };

        // Send store data to the server
        const response = await fetch("/store/add", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify(storeData)
        });

        const result = await response.json();

        if (result.success) {
          alert("Store added successfully!");
          // Optionally update the UI dynamically
          const collectionList = document.querySelector(".collection");
          const newStore = document.createElement("li");
          newStore.classList.add("collection-item");
          newStore.innerHTML = `
            <strong><a href="/store/${result.store.id}">${result.store.name}</a></strong>
            <p style="margin: 8px;">${result.store.address}</p>
            ${storeData.image ? `<img class="thumbnail" src="${storeData.image}" alt="Store Image">` : ""}
            <form action="/store/${result.store.id}/delete" method="POST" style="display:inline;">
              <button type="submit" class="btn red">Remove</button>
            </form>
          `;
          collectionList.appendChild(newStore);
        } else {
          alert("Failed to add store.");
        }
      });
    });
  });
</script>


</body>

</html>
