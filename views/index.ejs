<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vape Store Locator</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <link rel="stylesheet" href="/styles.css">
    <style>
        .add-store-form {
            display: none;
            padding: 15px;
            background: #f9f9f9;
            border-radius: 8px;
            margin-top: 15px;
        }
        #map {
            height: 400px;
            width: 100%;
            margin-top: 20px;
        }
        .thumbnail {
            display: block;
            margin-top: 10px;
            border-radius: 5px;
        }
        .add-button {
            display: block;
            margin: 10px auto;
            background-color: #007bff;
            color: white;
            padding: 10px 20px;
            border: none;
            cursor: pointer;
            border-radius: 5px;
        }
    </style>
</head>
<body>
    <%- include('header') %>

    <div class="container">
        <h1 class="center-align">Vape Store Locator</h1>
        
        <button class="add-button" id="fab">Add Store</button>
        
        <div class="add-store-form">
            <form action="/add-store" method="POST" class="col s12" enctype="multipart/form-data">
                <div class="row">
                    <div class="input-field col s6">
                        <input type="text" id="name" name="name" required>
                        <label for="name">Store Name</label>
                    </div>
                    <div class="input-field col s6">
                        <input type="text" id="address" name="address" required>
                        <label for="address">Address</label>
                    </div>
                    <div class="input-field col s6">
                        <input type="text" id="contact_info" name="contact_info" required>
                        <label for="contact_info">Contact Info</label>
                    </div>
                    <div class="input-field col s6">
                        <input type="file" id="image" name="image" accept="image/*" required>
                    </div>
                </div>
                <button type="submit" class="btn">Add Store</button>
            </form>
        </div>
        
        <ul class="collection">
            <% stores.forEach(store => { %>
                <li class="collection-item">
                    <strong><a href="/store/<%= store.id %>"><%= store.name %></a></strong>
                    <p style="margin: 8px;"><%= store.address %></p>
                    <% if (store.image) { %>
                        <img class="thumbnail" src="data:image/jpeg;base64,<%= store.image.toString('base64') %>" alt="Store Image">
                    <% } %>
                </li>
            <% }); %>
        </ul>

        <!-- Google Maps display -->
        <div id="map"></div>
    </div>

    <%- include('footer') %>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>

    <!-- Google Maps API script using .env -->
    <script src="https://maps.googleapis.com/maps/api/js?key=<%= googleMapsApiKey %>&callback=initMap" async defer></script>

    <script>
        document.getElementById('fab').onclick = function() {
            const form = document.querySelector('.add-store-form');
            form.style.display = form.style.display === 'block' ? 'none' : 'block';
        };

        function initMap() {
            const stores = <%- JSON.stringify(stores) %>; 
            const defaultLatLng = { lat: 37.7749, lng: -122.4194 }; 
            const firstStore = stores.length > 0 ? stores[0] : null;
            const center = firstStore ? { lat: firstStore.latitude, lng: firstStore.longitude } : defaultLatLng;

            const map = new google.maps.Map(document.getElementById('map'), {
                center: center,
                zoom: 12,
            });

            stores.forEach(store => {
                if (store.latitude && store.longitude) {
                    new google.maps.Marker({
                        position: { lat: store.latitude, lng: store.longitude },
                        map: map,
                        title: store.name,
                    });
                }
            });
        }
    </script>    
</body>
</html>
