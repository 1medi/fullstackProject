<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= store.name %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/css/materialize.min.css">
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <%- include('header') %>
    <div class="container">
        <% if (store.image) { %>
            <img class="banner" src="data:image/jpeg;base64,<%= store.image.toString('base64') %>" alt="Store Image">
        <% } %>
        <h1 class="center-align"><%= store.name %></h1>
        <p><strong>Address:</strong> <%= store.address %></p>
        <h2>Reviews</h2>
        <h2>Reviews</h2>
<div class="row">
  <div class="input-field col s6">
    <button id="sortReviews" class="btn waves-effect waves-light">
      Sort by Rating (High to Low)
    </button>
  </div>
</div>

<ul id="reviewList" class="collection">
  <% reviews.forEach(review => { %>
    <li class="collection-item review-item" data-rating="<%= review.rating %>" data-created-at="<%= review.created_at %>">
      <h3><%= review.reviewer_name %></h3>
      <p>Rating: <%= review.rating %></p>
      <p><%= review.comment %></p>
    </li>
  <% }); %>
</ul>

        </ul>
        <div class="row">
            <h3>Add a Review</h3>
            <div class="add-review-form">
                <form action="/add-review" method="POST" class="col s12" >
                    <div class="input-field col s6">
                        <input type="text" id="reviewerName" name="reviewerName" required>
                        <label for="reviewer_name">Name</label>
                    </div>
                    <div class="input-field col s6">
                        <input type="text" id="comment" name="comment" required>
                        <label for="comment">Review Text</label>
                    </div>
                    <div class="input-field col s6">
                        <input type="number" id="rating" name="rating" min="1" max="5" required>
                        <label for="rating">Rating (1-5)</label>
                    </div>
                    <!-- <div class="input-field col s6">
                        <input type="file" id="image" name="image" accept="image/*" required>
                    </div> -->
                    <input type="hidden" name="storeId" value="<%= store.id %>"> 
                    <button type="submit" class="btn">Add Review</button>
                </form>
            </div>
        </div>
        

    </div>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/1.0.0/js/materialize.min.js"></script>
    <script>
        document.getElementById('fab').onclick = function() {
            const form = document.querySelector('.add-store-form');
            form.style.display = form.style.display === 'block' ? 'none' : 'block';
        };
    </script>
    <script>
      document.addEventListener("DOMContentLoaded", function () {
        const sortButton = document.getElementById("sortReviews");
        const reviewList = document.getElementById("reviewList");
    
        // Get all reviews as an array of DOM elements
        let reviews = Array.from(reviewList.getElementsByClassName("review-item"));
    
        // Store initial order by most recent (default)
        const originalOrder = [...reviews];
    
        // Flag to track whether sorted by rating
        let sortedByRating = false;
    
        // Sort reviews by rating (High to Low)
        sortButton.addEventListener("click", function () {
          if (!sortedByRating) {
            // Sort by rating (high to low)
            reviews.sort((a, b) => {
              const ratingA = parseInt(a.getAttribute("data-rating"));
              const ratingB = parseInt(b.getAttribute("data-rating"));
              return ratingB - ratingA;
            });
    
            sortButton.innerText = "Sort by Most Recent";
          } else {
            // Revert to original order (most recent)
            reviews = [...originalOrder];
            sortButton.innerText = "Sort by Rating (High to Low)";
          }
    
          // Clear and re-append sorted reviews
          reviewList.innerHTML = "";
          reviews.forEach((review) => {
            reviewList.appendChild(review);
          });
    
          // Toggle flag
          sortedByRating = !sortedByRating;
        });
      });
    </script>
    
</body>
</html>
